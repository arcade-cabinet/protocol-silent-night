# Godot editor cache (generated, never commit)
.godot/

# Godot import metadata (generated per-environment)
*.translation.import

# Godot mono/C# (not used, but guard anyway)
.mono/

# Build artifacts — committed source (export_presets.cfg) is fine
export/
*.pck
*.zip
*.apk
*.aab

# Test/CI reports
reports/

# Intermediate build artifacts
.artifacts/
.gradle/
local.properties
build/

# Claude worktrees and runtime state
.claude/worktrees/
.claude/state/task-batch/.last-compaction
.claude/state/task-batch/.active

# Session temp files
.remember/tmp/

# Temp / OS
*.tmp
*.log
*~
.DS_Store
Thumbs.db

# Editor swap files
*.swp
*.swo
